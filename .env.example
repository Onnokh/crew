# Copy to .env for local dev (cp .env.example .env). Insecure dev defaults — change for prod.

CREW_AUTH_SECRET=dev-only-insecure-auth-secret-change-me-please

# Seeds the first admin on a fresh database
CREW_ADMIN_EMAIL=admin@example.com
CREW_ADMIN_PASSWORD=dev-admin-password
CREW_ADMIN_NAME=Dev Admin

# Tenancy split (ADR 0007/0008): one control-plane DB for identity + org/team/
# membership, plus a directory holding one corpus DB file per Team (named by team
# id). Replaces the old single CREW_DB_PATH.
CREW_CONTROL_PLANE_DB_PATH=crew-control-plane-dev.db
CREW_TEAMS_DIR=teams-dev

# Extra origins better-auth trusts (e.g. Vite dev console on :5173)
CREW_TRUSTED_ORIGINS=http://localhost:5173

# Public origin behind a reverse proxy; defaults to http://localhost:PORT
# CREW_BASE_URL=http://localhost:8087
