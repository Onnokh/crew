# Session signing secret for better-auth (see ADR 0003). REQUIRED — the server
# refuses to boot without a random string of at least 32 chars. Generate one
# with `openssl rand -hex 32` and keep it stable across restarts.
SOA_AUTH_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# First-admin bootstrap. On a fresh database the server seeds one Admin with
# this email + password (role=admin) so you can sign into the console; every
# other User and every agent API key is then provisioned from the admin page.
# CHANGE THESE before any real use. Password must be at least 8 chars.
SOA_ADMIN_EMAIL=admin@example.com
SOA_ADMIN_PASSWORD=change-me-please
SOA_ADMIN_NAME=Admin

# Public base URL better-auth builds its routes and session cookies against.
# Defaults to http://localhost:<PORT> if unset; set it to the externally
# reachable origin behind a reverse proxy.
# SOA_BASE_URL=http://localhost:8087

# Host port the container's MCP endpoint is published on. 8087 matches the
# agent-plugin default (packages/agent-plugin/.mcp.json → http://localhost:8087/mcp),
# so an installed plugin connects with no extra wiring.
SOA_HOST_PORT=8087
