{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "noEmit": true,
    // The server is a leaf application — nothing imports its TypeScript types
    // (the console talks to it over HTTP/JSON + better-auth, the claude-plugin
    // imports no TS). So we don't emit declarations, and turning the base's
    // `declaration` off here also lifts the declaration-only requirement that an
    // exported function's inferred return type be nameable — which better-auth's
    // instance type can't satisfy, as it transitively embeds better-sqlite3's
    // `export =` Database type (see src/auth/better-auth.ts).
    "declaration": false
  },
  "include": ["src"]
}
